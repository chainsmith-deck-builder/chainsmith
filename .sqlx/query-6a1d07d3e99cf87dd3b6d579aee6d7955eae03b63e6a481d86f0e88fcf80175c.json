  "query": "\n        SELECT\n            id, owner_id, format, hero_printing_id, name, description,\n            visibility, tags, created_at, updated_at, deleted_at\n        FROM decks\n        WHERE owner_id = $1 AND deleted_at IS NULL\n        ORDER BY updated_at DESC\n        ",
