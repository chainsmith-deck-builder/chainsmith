# Direct Postgres connection (port 5432). Used by the application in local
# dev and by sqlx-cli for migrations. In production this points at the
# Supabase pooler endpoint (port 6543) for the application, with a separate
# DATABASE_MIGRATION_URL on port 5432 for migrations.
DATABASE_URL=postgres://chainsmith:chainsmith@localhost:5432/chainsmith

# HTTP listener
BIND_ADDR=0.0.0.0:8080

# sqlx connection pool size
DB_MAX_CONNECTIONS=10

# Logging filter
RUST_LOG=info,chainsmith=debug,tower_http=debug
